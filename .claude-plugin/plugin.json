{
  "$schema": "https://claude.ai/schemas/plugin.json",
  "name": "2ndbrain-mogging",
  "version": "0.1.4",
  "description": "Obsidian vault automation for Claude Code. Save conversations, compile sources into a living wiki, audit the graph, challenge your own thinking. Amalgamation of Karpathy's LLM Wiki + Jens + eugeniu + AgriciDaniel + NicholasSpisak, hardened for operator vaults with live sync.",
  "author": {
    "name": "lorecraft-io",
    "email": "nate@lorecraft.io",
    "url": "https://github.com/lorecraft-io"
  },
  "license": "MIT",
  "homepage": "https://github.com/lorecraft-io/2ndBrain-mogging",
  "repository": {
    "type": "git",
    "url": "https://github.com/lorecraft-io/2ndBrain-mogging.git"
  },
  "engines": {
    "claude-code": ">=1.4.0"
  },
  "keywords": ["obsidian", "pkm", "zettelkasten", "second-brain", "vault", "karpathy-llm-wiki"],
  "skills": [
    {"name": "save", "path": "skills/save/SKILL.md"},
    {"name": "wiki", "path": "skills/wiki/SKILL.md"},
    {"name": "challenge", "path": "skills/challenge/SKILL.md"},
    {"name": "emerge", "path": "skills/emerge/SKILL.md"},
    {"name": "backfill", "path": "skills/backfill/SKILL.md"},
    {"name": "aliases", "path": "skills/aliases/SKILL.md"},
    {"name": "autoresearch", "path": "skills/autoresearch/SKILL.md"},
    {"name": "canvas", "path": "skills/canvas/SKILL.md"},
    {"name": "tether", "path": "skills/tether/SKILL.md"},
    {"name": "connect", "path": "skills/connect/SKILL.md"}
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-save.sh"
      }
    ]
  },
  "scheduled": [
    {"name": "morning", "plist": "scheduled/launchd/io.lorecraft.mogging.morning.plist"},
    {"name": "nightly", "plist": "scheduled/launchd/io.lorecraft.mogging.nightly.plist"},
    {"name": "weekly", "plist": "scheduled/launchd/io.lorecraft.mogging.weekly.plist"},
    {"name": "health", "plist": "scheduled/launchd/io.lorecraft.mogging.health.plist"}
  ]
}
