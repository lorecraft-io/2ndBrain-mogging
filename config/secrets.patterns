# ============================================================================
# config/secrets.patterns — bash-sourceable regex arrays
# ----------------------------------------------------------------------------
# Two arrays:
#   HARDBLOCK — match means FAIL CLOSED. Never ship, never bypass.
#   WARN      — match means pause and hand the finding to a human.
#
# Consume from scripts with:
#   # shellcheck disable=SC1091
#   source "config/secrets.patterns"
#   for pat in "${HARDBLOCK[@]}"; do
#     if grep -rE "$pat" . --exclude-dir=.git; then ...; fi
#   done
#
# Patterns are ERE-flavored so they work with `grep -E` on macOS + Linux.
# ============================================================================

# ----------------------------------------------------------------------------
# HARDBLOCK — exit non-zero on any match. Deny list. No overrides.
# ----------------------------------------------------------------------------
HARDBLOCK=(
  # Anthropic keys (user keys, project keys, service-account keys)
  'sk-ant-[A-Za-z0-9_-]{20,}'
  'sk-proj-[A-Za-z0-9_-]{20,}'
  'sk-svcacct-[A-Za-z0-9_-]{20,}'

  # Notion integration tokens
  'ntn_[A-Za-z0-9]{20,}'

  # GitHub classic and fine-grained tokens
  'ghp_[A-Za-z0-9]{36,}'
  'gho_[A-Za-z0-9]{36,}'
  'github_pat_[A-Za-z0-9_]{60,}'

  # AWS access key IDs (never the secret — that's matched by default rules)
  'AKIA[0-9A-Z]{16}'

  # Slack tokens (bot, user, app, refresh, config)
  'xox[baprs]-[A-Za-z0-9-]{10,}'

  # Google OAuth access tokens
  'ya29\.[A-Za-z0-9_-]{20,}'

  # Supabase service-role keys
  'sbp_[A-Za-z0-9]{40,}'

  # Stripe live keys (secret + restricted)
  'sk_live_[A-Za-z0-9]{24,}'
  'rk_live_[A-Za-z0-9]{24,}'

  # Cloudflare API tokens (v1.0-prefixed bearer)
  'v1\.0-[A-Za-z0-9_-]{20,}'

  # PEM private keys — any flavor
  '-----BEGIN (RSA |EC |DSA |OPENSSH |ENCRYPTED |PGP )?PRIVATE KEY-----'
)

# ----------------------------------------------------------------------------
# WARN — match means pause and ask a human. Not a hard block.
# ----------------------------------------------------------------------------
# Use case: test fixtures, webhook URLs with basic-auth creds, JWTs that
# might be demo tokens, generic "api_key = ..." patterns that often hit
# SDK examples. Humans decide.
WARN=(
  # Stripe publishable live keys — not secret, but still worth noting
  'pk_live_[A-Za-z0-9]{24,}'

  # Generic "api_key"/"apikey"/"api-key" assignments
  '(?i)api[_\-]?key\s*[:=]\s*["'\'']?[A-Za-z0-9_\-]{16,}'

  # JWTs (three base64url segments separated by dots)
  'eyJ[A-Za-z0-9_-]+\.eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+'

  # URL-embedded credentials (scheme://user:pass@host)
  '[a-z][a-z0-9+.-]*://[^\s:@/]+:[^\s:@/]+@[^\s/]+'
)

# Export so child processes inherit them when sourced at the top of a script.
export HARDBLOCK
export WARN
